# Typography
font-family = ""
font-family = Berkeley Mono
font-style = SemiBold
font-style-bold = ExtraBold
font-style-italic = SemiBold Oblique
font-style-bold-italic = ExtraBold Oblique
font-synthetic-style = false
font-size = 13
font-thicken = true
font-thicken-strength = 48
font-feature = -calt, -liga, -dlig
adjust-underline-position = 2
adjust-underline-thickness = -1
adjust-cursor-thickness = 15%

# Color
theme = Apple Classic
bold-color = bright
minimum-contrast = 1.1
background-opacity = 0.96
background-blur = 24
background-opacity-cells = true
unfocused-split-opacity = 0.82
unfocused-split-fill = #2c2b2b
split-divider-color = #6b5b02
search-foreground = #000000
search-background = #fffc67
search-selected-foreground = #000000
search-selected-background = #60fdff
faint-opacity = 0.65

# Cursor and selection
cursor-style = block
cursor-style-blink = false
cursor-color = cell-foreground
cursor-text = cell-background
mouse-hide-while-typing = true
mouse-shift-capture = true
mouse-scroll-multiplier = precision:1,discrete:5
selection-clear-on-copy = true
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
right-click-action = copy-or-paste

# Window
window-width = 120
window-height = 45
window-padding-x = 10
window-padding-y = 8
window-padding-balance = true
window-padding-color = extend
window-step-resize = true
window-save-state = always
window-inherit-font-size = false
window-theme = dark
window-colorspace = display-p3
window-new-tab-position = current
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = left
macos-dock-drop-behavior = new-tab
macos-auto-secure-input = true

# Terminal behavior
scrollback-limit = 134217728
scrollbar = never
scroll-to-bottom = keystroke
shell-integration = zsh
shell-integration-features = no-cursor
split-preserve-zoom = true
confirm-close-surface = false
copy-on-select = true
link-url = true
link-previews = true
quick-terminal-position = top
quick-terminal-size = 45%
quick-terminal-animation-duration = 0.12
quick-terminal-autohide = true
bell-features = no-system,no-audio,attention,no-title,border

# Keybindings
keybind = cmd+enter=toggle_fullscreen
keybind = cmd+shift+enter=toggle_split_zoom
keybind = cmd+t=new_tab
keybind = cmd+n=new_window
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_surface
keybind = cmd+alt+w=close_tab:this
keybind = cmd+shift+w=close_window
keybind = cmd+shift+z=toggle_split_zoom
keybind = cmd+z=undo
keybind = cmd+y=redo
keybind = cmd+,=open_config
keybind = cmd+shift+,=reload_config
keybind = cmd+k=clear_screen
keybind = cmd+shift+p=toggle_command_palette
keybind = cmd+f=start_search
keybind = cmd+g=navigate_search:next
keybind = cmd+shift+g=navigate_search:previous
keybind = cmd+e=search_selection
keybind = cmd+shift+f=end_search
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1
keybind = cmd+home=scroll_to_top
keybind = cmd+end=scroll_to_bottom
keybind = cmd+page_up=scroll_page_up
keybind = cmd+page_down=scroll_page_down
keybind = cmd+0=reset_font_size
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+shift+space=toggle_quick_terminal

keybind = cmd+alt+h=goto_split:left
keybind = cmd+alt+j=goto_split:down
keybind = cmd+alt+k=goto_split:up
keybind = cmd+alt+l=goto_split:right

keybind = cmd+shift+h=resize_split:left,20
keybind = cmd+shift+j=resize_split:down,20
keybind = cmd+shift+k=resize_split:up,20
keybind = cmd+shift+l=resize_split:right,20
keybind = cmd+shift+e=equalize_splits

keybind = shift+enter=text:\x1b\r
